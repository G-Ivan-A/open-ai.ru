# LLM настройки
# URL Ollama (по умолчанию — из docker-compose)
LLM_BASE_URL=http://ollama:11434

# Модель Ollama (рекомендации: llama3.2, phi3:mini, mistral)
LLM_MODEL=llama3.2

# Для использования внешнего OpenAI-совместимого API:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Безопасность (сгенерировать случайный токен)
# API_SECRET_TOKEN=your-secret-token-here

# Размер чанков при индексации документов (в символах)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
